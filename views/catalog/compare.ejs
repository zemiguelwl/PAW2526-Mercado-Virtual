<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Comparar | Mercadinho Virtual</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
<%- include('../partials/public-nav') %>
<div class="container pb-5">
  <%- include('../partials/flash') %>
  <p class="mb-2"><a href="/catalog">← Voltar ao catálogo</a></p>
  <h1 class="h3 mb-3">Comparar preços</h1>
  <form method="get" action="/catalog/compare" class="mb-4">
    <label class="form-label">Nome do produto</label>
    <div class="input-group" style="max-width:480px">
      <input class="form-control" name="name" value="<%= searchName %>" placeholder="ex: leite, água, pão">
      <button class="btn btn-primary" type="submit">Comparar</button>
    </div>
  </form>

  <p class="text-muted small">Mesmo produto em supermercados diferentes (pesquisa por texto no nome).</p>
  <div class="table-responsive">
    <table class="table table-bordered">
      <thead><tr><th>Produto</th><th>Supermercado</th><th class="text-end">Preço</th><th>Stock</th><th></th></tr></thead>
      <tbody>
        <% rows.forEach(r => { %>
          <tr>
            <td><%= r.name %></td>
            <td><%= r.supermarket?.name %><%= r.supermarket?.location ? ', ' + r.supermarket.location : '' %></td>
            <td class="text-end">€<%= Number(r.price).toFixed(2) %></td>
            <td><%= r.stock %></td>
            <td>
              <% if (user && user.role === 'client') { %>
                <form method="post" action="/client/cart/add" class="d-inline-flex gap-1">
                  <input type="hidden" name="productId" value="<%= r._id %>">
                  <input type="hidden" name="quantity" value="1">
                  <button class="btn btn-sm btn-success" type="submit">Adicionar</button>
                </form>
              <% } else { %>
                <a class="btn btn-sm btn-outline-primary" href="/auth/login?next=/catalog/compare?name=<%= encodeURIComponent(searchName) %>">Entrar</a>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% if (!rows.length) { %><p>Nenhum produto encontrado.</p><% } %>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
