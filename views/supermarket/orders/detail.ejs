<div class="bo-page-header">
  <div>
    <h1 class="h3 mb-1">Detalhe da encomenda</h1>
    <p class="bo-page-subtitle">Gestão de estado e validação de itens.</p>
  </div>
</div>

<div class="row g-3 mb-4">
  <div class="col-12 col-lg-8">
    <div class="card">
      <div class="card-body">
        <p class="mb-1"><strong>Referência:</strong> #<%= String(locals.order._id).slice(-6).toUpperCase() %></p>
        <p class="mb-1"><strong>Estado:</strong> <span class="badge bo-soft-badge"><%= locals.order.status %></span></p>
        <p class="mb-1"><strong>Cliente:</strong> <%= (locals.order.client && locals.order.client.name) || "N/A" %></p>
        <p class="mb-1"><strong>Email:</strong> <%= (locals.order.client && locals.order.client.email) || "Sem email" %></p>
        <p class="mb-0"><strong>Total:</strong> €<%= Number(locals.order.total || 0).toFixed(2) %></p>
      </div>
    </div>
  </div>
  <div class="col-12 col-lg-4">
    <div class="card">
      <div class="card-header bg-white">
        <h2 class="h5 mb-0">Transição de estado</h2>
      </div>
      <div class="card-body d-grid gap-2">
        <div class="card-body d-grid gap-2">
          <% if (locals.order.status === 'pending') { %>
            <form method="POST" action="/supermarket/orders/<%= locals.order._id %>/confirm">
              <button class="btn btn-primary w-100" type="submit">Confirmar Pedido</button>
            </form>
            <form method="POST" action="/supermarket/orders/<%= locals.order._id %>/reject">
              <input name="reason" class="form-control form-control-sm mb-2" placeholder="Motivo">
              <button class="btn btn-outline-danger w-100" type="submit">Rejeitar</button>
            </form>
          <% } else if (locals.order.status === 'confirmed') { %>
            <form method="POST" action="/supermarket/orders/<%= locals.order._id %>/start-preparing">
              <button class="btn btn-primary w-100" type="submit">Iniciar Preparação</button>
            </form>
          <% } else if (locals.order.status === 'preparing') { %>
            <form method="POST" action="/supermarket/orders/<%= locals.order._id %>/ready">
              <button class="btn btn-primary w-100" type="submit">Marcar como Pronta para Recolha</button>
            </form>
          <% } else if (locals.order.status === 'ready') { %>
            <div class="alert alert-info small mb-0">A aguardar que o estafeta recolha o pedido.</div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="card mb-4">
  <div class="card-header bg-white">
    <h2 class="h5 mb-0">Itens da encomenda</h2>
  </div>
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table align-middle mb-0">
        <thead>
          <tr>
            <th>Produto</th>
            <th>Qtd</th>
            <th>Preço</th>
            <th>Subtotal</th>
          </tr>
        </thead>
        <tbody>
          <% (locals.order.items || []).forEach((i) => { %>
            <tr>
              <td><%= i.productName %></td>
              <td><%= i.quantity %></td>
              <td>€<%= Number(i.productPrice || 0).toFixed(2) %></td>
              <td>€<%= Number((i.productPrice || 0) * (i.quantity || 0)).toFixed(2) %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>
