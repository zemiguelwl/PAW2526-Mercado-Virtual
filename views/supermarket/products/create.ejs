<p class="mb-2"><a href="/supermarket/products">← Voltar aos produtos</a></p>
<h2>Novo Produto</h2>
<form method="post" action="/supermarket/products" enctype="multipart/form-data">
  <input name="name" placeholder="Nome" required>
  <input name="price" type="number" step="0.01" placeholder="Preço" required>
  <input name="stock" type="number" placeholder="Stock" required>
  <select name="category" required>
    <% categories.forEach(c => { %><option value="<%= c._id %>"><%= c.name %></option><% }) %>
  </select>
  <textarea name="description" placeholder="Descrição"></textarea>
  <input type="file" name="image" accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp">
  <small>Formatos: jpg, jpeg, png, webp (max 5MB)</small>
  <button>Criar</button>
</form>
