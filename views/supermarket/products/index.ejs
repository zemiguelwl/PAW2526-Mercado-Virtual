<p class="mb-2"><a href="/supermarket/dashboard">← Voltar ao dashboard</a></p>
<h2>Produtos</h2>
<a href="/supermarket/products/create">Novo produto</a>
<form method="get" action="/supermarket/products">
  <input name="search" value="<%= search %>" placeholder="Pesquisar">
  <select name="category">
    <option value="">Todas categorias</option>
    <% categories.forEach(c => { %>
      <option value="<%= c._id %>" <%= String(currentCategory) === String(c._id) ? 'selected' : '' %>><%= c.name %></option>
    <% }) %>
  </select>
  <button>Filtrar</button>
</form>
<div class="row g-3">
  <% products.forEach(p => { %>
    <div class="col-12 col-sm-6 col-lg-4">
      <article class="card h-100 shadow-sm">
        <img src="<%= p.image || '/images/product-placeholder.svg' %>" class="card-img-top product-top-image" alt="Imagem de <%= p.name %>">
        <div class="card-body d-flex flex-column">
          <h3 class="h6 mb-1"><%= p.name %></h3>
          <p class="mb-1">€<%= Number(p.price).toFixed(2) %></p>
          <p class="text-muted mb-2">Stock: <%= p.stock %></p>
          <div class="mt-auto d-flex flex-wrap gap-2">
            <a class="btn btn-sm btn-outline-primary" href="/supermarket/products/<%= p._id %>/edit">Editar</a>
            <form method="post" action="/supermarket/products/<%= p._id %>?_method=DELETE" class="d-inline">
              <button class="btn btn-sm btn-outline-danger">Desativar</button>
            </form>
            <form method="post" action="/supermarket/products/<%= p._id %>/stock" class="d-inline d-flex gap-1 align-items-center">
              <input type="number" name="amount" value="1" class="form-control form-control-sm" style="max-width:85px">
              <button class="btn btn-sm btn-outline-secondary">Stock</button>
            </form>
          </div>
        </div>
      </article>
    </div>
  <% }) %>
</div>
