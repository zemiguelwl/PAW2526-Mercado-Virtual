<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Carrinho | Mercadinho Virtual</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
<%- include('../partials/public-nav') %>
<div class="container pb-5">
  <%- include('../partials/flash') %>
  <h1 class="h4">Carrinho</h1>
  <% if (supermarketName) { %><p class="text-muted">Supermercado: <strong><%= supermarketName %></strong> (uma encomenda = um supermercado)</p><% } %>

  <% if (!lines.length) { %>
    <p>O carrinho está vazio. <a href="/catalog">Ver catálogo</a></p>
  <% } else { %>
    <div class="table-responsive">
      <table class="table">
        <thead><tr><th>Produto</th><th class="text-end">Preço</th><th>Qtd</th><th class="text-end">Subtotal</th><th></th></tr></thead>
        <tbody>
          <% let sum = 0; lines.forEach(row => { %>
            <% if (!row.product) { %>
              <tr><td colspan="5" class="text-danger">Produto já não existe. Remova a linha.</td></tr>
            <% } else { const st = row.product.price * row.quantity; sum += st; %>
            <tr>
              <td><%= row.product.name %> <% if (row.invalid) { %><span class="badge bg-warning text-dark">Atualiza qtd</span><% } %></td>
              <td class="text-end">€<%= Number(row.product.price).toFixed(2) %></td>
              <td>
                <form method="post" action="/client/cart/update" class="d-flex gap-1">
                  <input type="hidden" name="productId" value="<%= row.productId %>">
                  <input class="form-control form-control-sm" type="number" name="quantity" value="<%= row.quantity %>" min="1" max="<%= row.product.stock %>" style="width:80px">
                  <button class="btn btn-sm btn-secondary" type="submit">OK</button>
                </form>
              </td>
              <td class="text-end">€<%= st.toFixed(2) %></td>
              <td>
                <form method="post" action="/client/cart/remove">
                  <input type="hidden" name="productId" value="<%= row.productId %>">
                  <button class="btn btn-sm btn-outline-danger" type="submit">Remover</button>
                </form>
              </td>
            </tr>
            <% } %>
          <% }) %>
        </tbody>
      </table>
    </div>
    <p><strong>Subtotal estimado:</strong> €<%= sum.toFixed(2) %></p>
    <% if (!lines.some(l => l.invalid || !l.product)) { %>
      <a class="btn btn-primary" href="/client/checkout">Finalizar encomenda</a>
    <% } else { %>
      <p class="text-danger">Corrige quantidades antes de finalizar.</p>
    <% } %>
  <% } %>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
