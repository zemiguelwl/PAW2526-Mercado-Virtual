<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Encomendas | Mercadinho Virtual</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
<%- include('../partials/public-nav') %>
<div class="container pb-5">
  <%- include('../partials/flash') %>
  <p class="mb-2"><a href="/client/dashboard">← Voltar à conta</a></p>
  <h1 class="h4">As minhas encomendas</h1>
  <div class="table-responsive mt-3">
    <table class="table table-sm">
      <thead><tr><th>Ref.</th><th>Data</th><th>Supermercado</th><th>Estado</th><th class="text-end">Total</th><th></th></tr></thead>
      <tbody>
        <% orders.forEach(o => { %>
          <tr>
            <td>#<%= o._id.toString().slice(-6).toUpperCase() %></td>
            <td><%= new Date(o.createdAt).toLocaleString('pt-PT') %></td>
            <td><%= o.supermarket?.name %></td>
            <td><%= o.status %></td>
            <td class="text-end">€<%= Number(o.total).toFixed(2) %></td>
            <td><a href="/client/orders/<%= o._id %>">Detalhe</a></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% if (!orders.length) { %><p class="text-muted">Ainda não tens encomendas.</p><% } %>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
