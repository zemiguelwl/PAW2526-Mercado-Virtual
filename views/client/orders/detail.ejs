<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Encomenda | Mercadinho Virtual</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
<%- include('../../partials/public-nav') %>
<div class="container pb-5">
  <%- include('../../partials/flash') %>
  <h1 class="h4">Encomenda #<%= order._id.toString().slice(-6).toUpperCase() %></h1>
  <p><strong>Estado:</strong> <%= order.status %></p>
  <p><strong>Supermercado:</strong> <%= order.supermarket?.name %></p>
  <p><strong>Total:</strong> €<%= Number(order.total).toFixed(2) %>; <strong>Entrega:</strong> <%= order.deliveryMethod %> (€<%= Number(order.deliveryCost).toFixed(2) %>)</p>
  <h2 class="h6 mt-4">Itens</h2>
  <ul>
    <% order.items.forEach(i => { %>
      <li><%= i.productName %> × <%= i.quantity %> @ €<%= Number(i.productPrice).toFixed(2) %></li>
    <% }) %>
  <ul>
    <% order.items.forEach(i => { %>
      <li><%= i.productName %> × <%= i.quantity %> @ €<%= Number(i.productPrice).toFixed(2) %></li>
    <% }) %>
  </ul>

  <% if (delivery) { %>
    <div class="card mt-4">
      <div class="card-header">
        <h5 class="mb-0">Informações de Entrega</h5>
      </div>
      <div class="card-body">
        <p><strong>Estado:</strong> <%= delivery.status %></p>
        <% if (delivery.courier) { %>
          <p><strong>Estafeta:</strong> <%= delivery.courier.name %><% if (delivery.courier.phone) { %> (Tel: <%= delivery.courier.phone %>)<% } %></p>
          <% if (delivery.acceptedAt) { %>
            <p><small class="text-muted">Aceite em: <%= new Date(delivery.acceptedAt).toLocaleString('pt-PT') %></small></p>
          <% } %>
        <% } else { %>
          <p><small class="text-muted">À espera de atribuição de estafeta...</small></p>
        <% } %>
      </div>
    </div>
  <% } %>

  <% if (order.status === 'delivered' && !order.reviewSubmitted) { %>
    <div class="alert alert-info mt-3">
      <p>Ajuda-nos a melhorar! <a href="/client/orders/<%= order._id %>/review">Deixa a tua avaliação →</a></p>
    </div>
  <% } %>

  <% if (canCancel) { %>
    <form method="post" action="/client/orders/<%= order._id %>/cancel" class="mt-3 js-confirm-cancel-order">
      <input class="form-control mb-2" name="reason" placeholder="Motivo (opcional)">
      <button class="btn btn-outline-danger" type="submit">Cancelar encomenda</button>
    </form>
  <% } %>
  <p class="mt-3"><a href="/client/orders">← Voltar às encomendas</a> · <a href="/client/dashboard">Conta</a></p>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/javascripts/client-order-detail.js"></script>
</body>
</html>
