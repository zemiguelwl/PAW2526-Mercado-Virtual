<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Perfil | Mercadinho Virtual</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
<%- include('../partials/public-nav') %>
<div class="container" style="max-width:560px">
  <%- include('../partials/flash') %>
  <h1 class="h4 mb-3">Perfil</h1>
  <form method="post" action="/client/profile">
    <div class="mb-2"><label class="form-label">Nome</label><input class="form-control" name="name" value="<%= user.name %>" required></div>
    <div class="mb-2"><label class="form-label">Email</label><input class="form-control" value="<%= user.email %>" disabled></div>
    <div class="mb-2"><label class="form-label">Telefone</label><input class="form-control" name="phone" value="<%= user.phone %>"></div>
    <div class="mb-3"><label class="form-label">Morada</label><textarea class="form-control" name="address" rows="2"><%= user.address %></textarea></div>
    <button class="btn btn-primary" type="submit">Guardar</button>
  </form>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
