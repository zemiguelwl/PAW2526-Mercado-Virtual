<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Checkout | Mercadinho Virtual</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
<%- include('../partials/public-nav') %>
<div class="container pb-5" style="max-width:640px">
  <%- include('../partials/flash') %>
  <h1 class="h4">Finalizar encomenda</h1>
  <p><strong><%= supermarket.name %></strong></p>
  <ul class="mb-3">
    <% lines.forEach(l => { %>
      <li><%= l.product.name %> × <%= l.quantity %> por €<%= (l.product.price * l.quantity).toFixed(2) %></li>
    <% }) %>
  </ul>
  <p>Subtotal: <strong>€<%= subtotal.toFixed(2) %></strong></p>

  <% if (!deliveryOptions.length) { %>
    <div class="alert alert-warning">Este supermercado não tem métodos de entrega configurados para compra online. Contacta o suporte.</div>
  <% } else { %>
    <form method="post" action="/client/checkout">
      <label class="form-label">Método de entrega</label>
      <% deliveryOptions.forEach((m, idx) => { %>
        <div class="form-check">
          <input class="form-check-input" type="radio" name="deliveryMethod" value="<%= m.type %>" id="dm_<%= m.type %>" <%= idx === 0 ? 'checked' : '' %> required>
          <label class="form-check-label" for="dm_<%= m.type %>"><%= m.label || m.type %> (€<%= Number(m.cost).toFixed(2) %>)</label>
        </div>
      <% }) %>
      <button class="btn btn-success mt-3" type="submit">Confirmar encomenda</button>
    </form>
  <% } %>
  <p class="mt-3"><a href="/client/cart">← Carrinho</a></p>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
