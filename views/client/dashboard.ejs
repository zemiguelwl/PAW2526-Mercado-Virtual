<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Conta | Mercadinho Virtual</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
<%- include('../partials/public-nav') %>
<div class="container pb-5">
  <%- include('../partials/flash') %>
  <h1 class="h4">Olá, <%= user.name %></h1>
  <div class="row g-3 mt-2">
    <div class="col-md-6">
      <div class="card"><div class="card-body">
        <h2 class="h6">Encomendas</h2>
        <p class="display-6"><%= orderCount %></p>
        <a href="/client/orders">Ver histórico</a>
      </div></div>
    </div>
    <div class="col-md-6">
      <div class="card"><div class="card-body">
        <h2 class="h6">Produtos mais comprados (entregues)</h2>
        <% if (topProducts.length) { %>
          <ul class="mb-0"><% topProducts.forEach(t => { %><li><%= t._id %>: <%= t.totalQty %> un.</li><% }) %></ul>
        <% } else { %><p class="text-muted mb-0">Ainda sem dados.</p><% } %>
      </div></div>
    </div>
  </div>
  <p class="mt-3"><a href="/catalog">Continuar a comprar</a></p>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
