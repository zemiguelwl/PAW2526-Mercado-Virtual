<!doctype html>
<html lang="pt"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1"><title>Verificar Email</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"></head>
<body class="bg-light"><div class="container py-5"><div class="row justify-content-center"><div class="col-md-5"><div class="card"><div class="card-body">
<h3>Verificar Email</h3>
<p>Enviámos um código para <strong><%= email %></strong></p>
<%- include('../partials/flash') %>
<form method="post" action="/auth/verify-email"><input class="form-control mb-3" name="code" placeholder="Código de 6 dígitos"><button class="btn btn-primary w-100">Verificar</button></form>
<form class="mt-2" method="post" action="/auth/resend-verification"><button class="btn btn-outline-secondary w-100">Reenviar código</button></form>
</div></div></div></div></div></body></html>
