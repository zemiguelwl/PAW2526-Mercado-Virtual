<!doctype html>
<html lang="pt">
<head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1"><title>Login</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"></head>
<body class="bg-light">
<div class="container py-5"><div class="row justify-content-center"><div class="col-md-5">
  <div class="card"><div class="card-body">
    <h3>Login</h3>
    <%- include('../partials/flash') %>
    <form method="post" action="/auth/login">
      <% if (typeof next !== 'undefined' && next) { %><input type="hidden" name="next" value="<%= next %>"><% } %>
      <div class="mb-3"><label>Email</label><input class="form-control" name="email" type="email" required></div>
      <div class="mb-3"><label>Password</label><input class="form-control" name="password" type="password" required></div>
      <button class="btn btn-primary w-100">Entrar</button>
    </form>
    <a class="d-block mt-3" href="/auth/register">Criar conta</a>
  </div></div>
</div></div></div>
</body></html>
