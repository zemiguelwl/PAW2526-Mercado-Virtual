<div class="bo-page-header">
  <div>
    <h1 class="h3 mb-1">Novo produto</h1>
    <p class="bo-page-subtitle">Adicionar novo item ao catálogo da loja.</p>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <form method="POST" action="/supermarket/products" enctype="multipart/form-data" class="row g-3">
      <div class="col-12 col-md-6">
        <label for="name" class="form-label">Nome</label>
        <input id="name" name="name" class="form-control" required>
      </div>
      <div class="col-12 col-md-3">
        <label for="price" class="form-label">Preço (€)</label>
        <input id="price" name="price" type="number" step="0.01" min="0" class="form-control" required>
      </div>
      <div class="col-12 col-md-3">
        <label for="stock" class="form-label">Stock</label>
        <input id="stock" name="stock" type="number" min="0" class="form-control" required>
      </div>
      <div class="col-12 col-md-6">
        <label for="category" class="form-label">Categoria</label>
        <select id="category" name="category" class="form-select" required>
          <% (locals.categories || []).forEach((c) => { %>
            <option value="<%= c._id %>"><%= c.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-12 col-md-6">
        <label for="image" class="form-label">Imagem</label>
        <input id="image" type="file" name="image" class="form-control" accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp" required>
        <div class="form-text">Formatos: jpg, jpeg, png, webp (máx. 5MB).</div>
      </div>
      <div class="col-12">
        <label for="description" class="form-label">Descrição</label>
        <textarea id="description" name="description" class="form-control" rows="3"></textarea>
      </div>
      <div class="col-12">
        <button class="btn btn-primary" type="submit">Criar produto</button>
      </div>
    </form>
  </div>
</div>
