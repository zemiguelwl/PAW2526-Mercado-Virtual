<div class="row justify-content-center">
  <div class="col-12 col-md-10 col-lg-8">
    <div class="card border-0 shadow-sm text-center">
      <div class="card-body p-4 p-md-5">
        <div class="display-4 fw-bold text-danger">500</div>
        <h1 class="h3 mt-2">Erro interno do servidor</h1>
        <p class="text-muted mb-4"><%= locals.message || "Ocorreu um erro inesperado. Tenta novamente dentro de instantes." %></p>

        <div class="d-flex justify-content-center flex-wrap gap-2">
          <a class="btn btn-primary" href="/catalog">Ir para o catálogo</a>
          <% if (locals.user) { %>
            <% if (locals.user.role === "admin") { %><a class="btn btn-outline-secondary" href="/admin/dashboard">Dashboard</a><% } %>
            <% if (locals.user.role === "supermarket") { %><a class="btn btn-outline-secondary" href="/supermarket/dashboard">Dashboard</a><% } %>
            <% if (locals.user.role === "courier") { %><a class="btn btn-outline-secondary" href="/courier/dashboard">Dashboard</a><% } %>
            <% if (locals.user.role === "client") { %><a class="btn btn-outline-secondary" href="/client/dashboard">Conta</a><% } %>
          <% } else { %>
            <a class="btn btn-outline-secondary" href="/auth/login">Entrar</a>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>
