<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="utf-8">
  <title><%= title || 'Erro' %></title>
</head>
<body>
  <h1><%= title || 'Erro' %></h1>
  <% if (typeof message !== 'undefined' && message) { %>
    <p><%= message %></p>
  <% } %>
  <p><a href="/">Voltar ao início</a></p>
</body>
</html>
