<div class="bo-page-header">
  <div>
    <h1 class="h3 mb-1">Criar cupão global</h1>
    <p class="bo-page-subtitle">Configuração de regras de desconto da plataforma.</p>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <form method="POST" action="/admin/coupons" class="row g-3">
      <div class="col-12 col-md-4">
        <label for="code" class="form-label">Código</label>
        <input id="code" name="code" class="form-control" placeholder="EX: BEMVINDO10" required>
      </div>

      <div class="col-12 col-md-8">
        <label for="description" class="form-label">Descrição</label>
        <input id="description" name="description" class="form-control" placeholder="Descrição opcional do cupão">
      </div>

      <div class="col-12 col-md-4">
        <label for="discountType" class="form-label">Tipo de desconto</label>
        <select id="discountType" name="discountType" class="form-select" required>
          <option value="percentage">Percentagem no subtotal</option>
          <option value="fixed_amount">Valor fixo</option>
          <option value="fixed_shipping">Entrega gratuita</option>
        </select>
      </div>

      <div class="col-12 col-md-4">
        <label for="discountValue" class="form-label">Valor de desconto</label>
        <input id="discountValue" name="discountValue" type="number" step="0.01" class="form-control" required>
      </div>

      <div class="col-12 col-md-4">
        <label for="minOrderValue" class="form-label">Valor mínimo da encomenda</label>
        <input id="minOrderValue" name="minOrderValue" type="number" step="0.01" class="form-control" value="0">
      </div>

      <div class="col-12 col-md-4">
        <label for="maxUses" class="form-label">Máximo de usos (opcional)</label>
        <input id="maxUses" name="maxUses" type="number" class="form-control" placeholder="Ex: 100">
      </div>

      <div class="col-12 col-md-4">
        <label for="validFrom" class="form-label">Válido a partir de</label>
        <input id="validFrom" name="validFrom" type="date" class="form-control" required>
      </div>

      <div class="col-12 col-md-4">
        <label for="validUntil" class="form-label">Válido até</label>
        <input id="validUntil" name="validUntil" type="date" class="form-control" required>
      </div>

      <div class="col-12">
        <button type="submit" class="btn btn-primary">Criar cupão</button>
      </div>
    </form>
  </div>
</div>
