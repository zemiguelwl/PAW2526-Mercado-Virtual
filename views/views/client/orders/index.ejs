<div class="container pb-5">
  <div class="bo-page-header">
    <div>
      <h1 class="h3 mb-1">As minhas encomendas</h1>
      <p class="bo-page-subtitle">Histórico de compras e estados.</p>
    </div>
    <a class="btn btn-outline-secondary btn-sm" href="/client/dashboard">Voltar à conta</a>
  </div>
  <div class="card">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table align-middle mb-0">
      <thead><tr><th>Ref.</th><th>Data</th><th>Supermercado</th><th>Estado</th><th class="text-end">Total</th><th></th></tr></thead>
      <tbody>
        <% orders.forEach(o => { %>
          <tr>
            <td>#<%= o._id.toString().slice(-6).toUpperCase() %></td>
            <td><%= new Date(o.createdAt).toLocaleString('pt-PT') %></td>
            <td><%= o.supermarket?.name %></td>
            <td><span class="badge bo-soft-badge"><%= o.status %></span></td>
            <td class="text-end">€<%= Number(o.total).toFixed(2) %></td>
            <td><a class="btn btn-sm btn-outline-primary" href="/client/orders/<%= o._id %>">Detalhe</a></td>
          </tr>
        <% }) %>
      </tbody>
        </table>
      </div>
    </div>
  </div>
  <% if (!orders.length) { %><p class="bo-empty-state mt-3">Ainda não tens encomendas.</p><% } %>
</div>
