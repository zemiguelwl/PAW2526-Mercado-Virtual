<div class="container pb-5">
  <div class="bo-page-header">
    <div>
      <h1 class="h3 mb-1">Carrinho</h1>
      <% if (supermarketName) { %>
        <p class="bo-page-subtitle">Supermercado: <strong><%= supermarketName %></strong> (uma encomenda = um supermercado)</p>
      <% } else { %>
        <p class="bo-page-subtitle">Revê e ajusta os itens antes de finalizar.</p>
      <% } %>
    </div>
  </div>

  <% if (!lines.length) { %>
    <p class="bo-empty-state">O carrinho está vazio. <a href="/catalog">Ver catálogo</a></p>
  <% } else { %>
    <div class="card">
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table align-middle mb-0">
        <thead><tr><th>Produto</th><th class="text-end">Preço</th><th>Qtd</th><th class="text-end">Subtotal</th><th></th></tr></thead>
        <tbody>
          <% let sum = 0; lines.forEach(row => { %>
            <% if (!row.product) { %>
              <tr><td colspan="5" class="text-danger">Produto já não existe. Remova a linha.</td></tr>
            <% } else { const st = row.product.price * row.quantity; sum += st; %>
            <tr>
              <td><%= row.product.name %> <% if (row.invalid) { %><span class="badge text-bg-warning">Atualiza qtd</span><% } %></td>
              <td class="text-end">€<%= Number(row.product.price).toFixed(2) %></td>
              <td>
                <form method="post" action="/client/cart/update" class="d-flex gap-1">
                  <input type="hidden" name="productId" value="<%= row.productId %>">
                  <input class="form-control form-control-sm" type="number" name="quantity" value="<%= row.quantity %>" min="1" max="<%= row.product.stock %>" style="width:80px">
                  <button class="btn btn-sm btn-secondary" type="submit">OK</button>
                </form>
              </td>
              <td class="text-end">€<%= st.toFixed(2) %></td>
              <td>
                <form method="post" action="/client/cart/remove">
                  <input type="hidden" name="productId" value="<%= row.productId %>">
                  <button class="btn btn-sm btn-outline-danger" type="submit">Remover</button>
                </form>
              </td>
            </tr>
            <% } %>
          <% }) %>
        </tbody>
          </table>
        </div>
      </div>
    </div>
    <p class="mt-3 mb-2"><strong>Subtotal estimado:</strong> €<%= sum.toFixed(2) %></p>
    <% if (!lines.some(l => l.invalid || !l.product)) { %>
      <a class="btn btn-primary" href="/client/checkout">Finalizar encomenda</a>
    <% } else { %>
      <p class="text-danger mb-0">Corrige quantidades antes de finalizar.</p>
    <% } %>
  <% } %>
</div>
