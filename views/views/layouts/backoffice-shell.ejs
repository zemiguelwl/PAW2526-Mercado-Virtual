<!doctype html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title || "Mercadinho Virtual" %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/backoffice.css">
</head>
<body>
  <div class="bo-app">
    <aside class="bo-sidebar">
      <div class="bo-sidebar-brand">
        <span class="bo-sidebar-brand-icon"><i class="bi bi-shop"></i></span>
        <span>Mercadinho Virtual</span>
      </div>

      <nav class="bo-nav">
        <% const pathNow = typeof locals.currentPath === "string" ? locals.currentPath : ""; %>
        <% if (locals.user && locals.user.role === "admin") { %>
          <a href="/admin/dashboard" class="bo-nav-link <%= pathNow === '/admin/dashboard' ? 'bo-active' : '' %>"><i class="bi bi-speedometer2"></i><span>Dashboard</span></a>
          <a href="/admin/supermarkets" class="bo-nav-link <%= pathNow === '/admin/supermarkets' ? 'bo-active' : '' %>"><i class="bi bi-shop-window"></i><span>Supermercados</span></a>
          <a href="/admin/users" class="bo-nav-link <%= pathNow === '/admin/users' ? 'bo-active' : '' %>"><i class="bi bi-people"></i><span>Utilizadores</span></a>
          <a href="/admin/orders" class="bo-nav-link <%= pathNow === '/admin/orders' ? 'bo-active' : '' %>"><i class="bi bi-bag-check"></i><span>Encomendas</span></a>
          <a href="/admin/categories" class="bo-nav-link <%= pathNow === '/admin/categories' ? 'bo-active' : '' %>"><i class="bi bi-tags"></i><span>Categorias</span></a>
          <a href="/admin/coupons" class="bo-nav-link <%= pathNow === '/admin/coupons' ? 'bo-active' : '' %>"><i class="bi bi-ticket-perforated"></i><span>Cupões</span></a>
        <% } %>

        <% if (locals.user && locals.user.role === "supermarket") { %>
          <a href="/supermarket/dashboard" class="bo-nav-link <%= pathNow === '/supermarket/dashboard' ? 'bo-active' : '' %>"><i class="bi bi-speedometer2"></i><span>Dashboard</span></a>
          <a href="/supermarket/profile" class="bo-nav-link <%= pathNow === '/supermarket/profile' ? 'bo-active' : '' %>"><i class="bi bi-shop"></i><span>Perfil</span></a>
          <a href="/supermarket/products" class="bo-nav-link <%= pathNow === '/supermarket/products' ? 'bo-active' : '' %>"><i class="bi bi-box-seam"></i><span>Produtos</span></a>
          <a href="/supermarket/orders" class="bo-nav-link <%= pathNow === '/supermarket/orders' ? 'bo-active' : '' %>"><i class="bi bi-receipt"></i><span>Encomendas</span></a>
          <a href="/supermarket/coupons" class="bo-nav-link <%= pathNow === '/supermarket/coupons' ? 'bo-active' : '' %>"><i class="bi bi-ticket-perforated"></i><span>Cupões</span></a>
          <a href="/supermarket/reviews" class="bo-nav-link <%= pathNow === '/supermarket/reviews' ? 'bo-active' : '' %>"><i class="bi bi-star"></i><span>Avaliações</span></a>
          <a href="/supermarket/pos" class="bo-nav-link <%= pathNow === '/supermarket/pos' ? 'bo-active' : '' %>"><i class="bi bi-calculator"></i><span>POS</span></a>
        <% } %>

        <% if (locals.user && locals.user.role === "courier") { %>
          <a href="/courier/dashboard" class="bo-nav-link <%= pathNow === '/courier/dashboard' ? 'bo-active' : '' %>"><i class="bi bi-speedometer2"></i><span>Dashboard</span></a>
          <a href="/courier/available" class="bo-nav-link <%= pathNow === '/courier/available' ? 'bo-active' : '' %>"><i class="bi bi-truck"></i><span>Disponíveis</span></a>
          <a href="/courier/history" class="bo-nav-link <%= pathNow === '/courier/history' ? 'bo-active' : '' %>"><i class="bi bi-clock-history"></i><span>Histórico</span></a>
          <a href="/courier/reviews" class="bo-nav-link <%= pathNow === '/courier/reviews' ? 'bo-active' : '' %>"><i class="bi bi-star"></i><span>Avaliações</span></a>
        <% } %>

        <% if (locals.user && locals.user.role === "client") { %>
          <a href="/catalog" class="bo-nav-link <%= pathNow === '/catalog' ? 'bo-active' : '' %>"><i class="bi bi-grid"></i><span>Catálogo</span></a>
          <a href="/catalog/compare" class="bo-nav-link <%= pathNow === '/catalog/compare' ? 'bo-active' : '' %>"><i class="bi bi-arrow-left-right"></i><span>Comparar Preços</span></a>
          <div style="border-top: 1px solid rgba(255, 255, 255, 0.1); margin: 0.75rem 0; padding-top: 0.75rem;">
            <a href="/client/dashboard" class="bo-nav-link <%= pathNow === '/client/dashboard' ? 'bo-active' : '' %>"><i class="bi bi-speedometer2"></i><span>Dashboard</span></a>
            <a href="/client/cart" class="bo-nav-link <%= pathNow === '/client/cart' ? 'bo-active' : '' %>"><i class="bi bi-cart3"></i><span>Carrinho</span></a>
            <a href="/client/orders" class="bo-nav-link <%= pathNow.startsWith('/client/orders') ? 'bo-active' : '' %>"><i class="bi bi-bag-check"></i><span>Encomendas</span></a>
            <a href="/client/profile" class="bo-nav-link <%= pathNow.startsWith('/client/profile') ? 'bo-active' : '' %>"><i class="bi bi-person"></i><span>Conta</span></a>
          </div>
        <% } %>

        <% if (!locals.user) { %>
          <a href="/catalog" class="bo-nav-link"><i class="bi bi-grid"></i><span>Catálogo</span></a>
          <a href="/auth/login" class="bo-nav-link"><i class="bi bi-box-arrow-in-right"></i><span>Entrar</span></a>
          <a href="/auth/register" class="bo-nav-link"><i class="bi bi-person-plus"></i><span>Registar</span></a>
        <% } %>
      </nav>
    </aside>

    <div class="bo-main">
      <header class="bo-topbar">
        <% if (locals.user && locals.user.role === "client") { %>
          <form method="get" action="/catalog" class="bo-topbar-search">
            <i class="bi bi-search"></i>
            <input type="search" name="q" placeholder="Pesquisar no catálogo...">
          </form>
        <% } else { %>
          <div></div>
        <% } %>
        <div class="bo-topbar-actions">
          <% if (locals.user && locals.user.role === "client") { %>
            <a href="/client/cart" class="btn bo-icon-btn d-inline-flex align-items-center justify-content-center" title="Carrinho" aria-label="Carrinho">
              <i class="bi bi-cart3"></i>
            </a>
            <div class="bo-user-chip">
              <span class="bo-user-avatar"><%= String(locals.user.name || "U").charAt(0).toUpperCase() %></span>
              <div>
                <div class="bo-user-name"><%= locals.user.name %></div>
              </div>
            </div>
            <form method="POST" action="/auth/logout">
              <button type="submit" class="btn btn-sm bo-btn-outline">Sair</button>
            </form>
          <% } else if (locals.user) { %>
            <div class="bo-user-chip">
              <span class="bo-user-avatar"><%= String(locals.user.name || "U").charAt(0).toUpperCase() %></span>
              <div>
                <div class="bo-user-name"><%= locals.user.name %></div>
                <div class="bo-user-role"><%= locals.user.role %></div>
              </div>
            </div>
            <form method="POST" action="/auth/logout">
              <button type="submit" class="btn btn-sm bo-btn-outline">Sair</button>
            </form>
          <% } %>
        </div>
      </header>

      <main class="bo-content">
        <%- include("../partials/flash") %>
        <%- body %>
      </main>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
