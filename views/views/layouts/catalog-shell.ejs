<!doctype html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title || "Mercadinho Virtual" %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/backoffice.css">
  <link rel="stylesheet" href="/stylesheets/backoffice.css">
</head>
<body>
  <div class="bo-app">
    <aside class="bo-sidebar">
      <div class="bo-sidebar-brand">
        <span class="bo-sidebar-brand-icon"><i class="bi bi-shop"></i></span>
        <span>Mercadinho Virtual</span>
      </div>

      <nav class="bo-nav">
        <a href="/catalog" class="bo-nav-link <%= currentPath === '/catalog' ? 'bo-active' : '' %>">
          <i class="bi bi-grid"></i><span>Catálogo</span>
        </a>
        <a href="/catalog/compare" class="bo-nav-link <%= currentPath === '/catalog/compare' ? 'bo-active' : '' %>">
          <i class="bi bi-arrow-left-right"></i><span>Comparar Preços</span>
        </a>
        <% if (locals.user && locals.user.role === "client") { %>
          <div style="border-top: 1px solid rgba(255, 255, 255, 0.1); margin: 0.75rem 0; padding-top: 0.75rem;">
            <a href="/client/dashboard" class="bo-nav-link <%= currentPath === '/client/dashboard' ? 'bo-active' : '' %>">
              <i class="bi bi-speedometer2"></i><span>Dashboard</span>
            </a>
            <a href="/client/cart" class="bo-nav-link <%= currentPath === '/client/cart' ? 'bo-active' : '' %>">
              <i class="bi bi-cart3"></i><span>Carrinho</span>
            </a>
            <a href="/client/orders" class="bo-nav-link <%= currentPath.startsWith('/client/orders') ? 'bo-active' : '' %>">
              <i class="bi bi-bag-check"></i><span>Encomendas</span>
            </a>
            <a href="/client/profile" class="bo-nav-link <%= currentPath.startsWith('/client/profile') ? 'bo-active' : '' %>">
              <i class="bi bi-person"></i><span>Conta</span>
            </a>
          </div>
        <% } %>
      </nav>
    </aside>

    <div class="bo-main">
      <header class="bo-topbar">
        

        <div class="bo-topbar-actions">
          <% if (locals.user) { %>
            <div class="bo-user-chip">
              <span class="bo-user-avatar"><%= String(locals.user.name || "U").charAt(0).toUpperCase() %></span>
              <div>
                <div class="bo-user-name"><%= locals.user.name %></div>
              </div>
            </div>
            <form method="POST" action="/auth/logout">
              <button type="submit" class="btn btn-sm bo-btn-outline">Sair</button>
            </form>
          <% } else { %>
            <a href="/auth/login" class="btn btn-sm bo-btn-outline">
              <i class="bi bi-box-arrow-in-right me-1"></i>Entrar
            </a>
            <a href="/auth/register" class="btn btn-sm btn-success">
              <i class="bi bi-person-plus me-1"></i>Registar
            </a>
          <% } %>
        </div>
      </header>

      <main class="bo-content">
        <div class="container-fluid pb-4">
          <%- include("../partials/flash") %>
          <%- body %>
        </div>
      </main>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
